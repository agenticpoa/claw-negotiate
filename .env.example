# claw-negotiate skill setup
#
# Copy this file to .env, edit the values, then run:
# python3 negotiate_safe/run_safe.py operator-setup --env-file .env

# founder or investor
NEGOTIATE_SAFE_BOT_ROLE=founder

# Your already-paired OpenClaw Telegram bot handle.
TELEGRAM_BOT_USERNAME=@YourOpenClawBot

# Your APOA/OpenClaw DID.
USER_DID=did:example:replace-me

# Shared signing/audit service.
SSHSIGN_HOST=sshsign.dev

# How often the skill checks for joined counterparties.
CLAW_NEGOTIATE_SCAN_INTERVAL=5s
